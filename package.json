{
    "name": "use-serversent-events",
    "version": "1.0.0",
    "description": "React hook for Server-Sent Events (SSE)",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "tsdown src/index.ts --format cjs,esm --watch --dts",
        "build": "tsdown src/index.ts --format cjs,esm --dts --clean --minify",
        "test": "vitest"
    },
    "keywords": [
        "react",
        "hook",
        "sse",
        "server-sent events"
    ],
    "author": "Christian Sanchez",
    "license": "MIT",
    "packageManager": "pnpm@10.33.0",
    "peerDependencies": {
        "react": ">=18"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.1.1",
        "jsdom": "^29.1.1",
        "prettier": "^3.8.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2",
        "vitest": "^4.1.5"
    }
}
